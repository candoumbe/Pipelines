<Project Sdk="Microsoft.NET.Sdk">

  <Import Project="../../core.props"/>
  <PropertyGroup>
    <TargetFrameworks>net8.0</TargetFrameworks>
    <Description>A Stater development kit to script your CI/CD using [Nuke](https://nuke.build).</Description>
    <PackageTags>build, pipeline, ci, workflow</PackageTags>
    <NukeBaseDirectory>$(MsBuildProjectDirectory)\tools</NukeBaseDirectory>
    <NukeUseNestedNamespaces>true</NukeUseNestedNamespaces>
    <NukeBaseNamespace>Candoumbe.Pipelines.Tools</NukeBaseNamespace>
    <NukeUpdateReferences>true</NukeUpdateReferences>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Nuke.Common"/>
    <PackageReference Include="Microsoft.TeamFoundationServer.Client" />
  </ItemGroup>

  <ItemGroup>
    <NukeSpecificationFiles Include="tools\Podman\Podman.json" />
    <NukeSpecificationFiles Include="tools\Stryker\Stryker.json" />
  </ItemGroup>
</Project>